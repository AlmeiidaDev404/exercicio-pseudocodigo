algoritmo "categorizacaoDeAtletas"

var
  idade: inteiro

inicio
     escreva("Jogador lol qual é sua idade?")
   leia(idade)

  se idade < 12 entao
    escreva("Jogador fora das categorias")
  senao se idade >= 12 e idade <=14 entao
    escreva("Jogador Mirim.")
  senao se idade >=15 e idade <=17 entao
    escreva("Jogador Junior!")
  senao se idade >=18 e idade <=25 entao
    escreva("Jogador Profissional!!")
  senao
    escreva("Master")
fimse
fimse
fimse
fimse

fimalgoritmo

